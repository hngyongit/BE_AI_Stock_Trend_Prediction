NODE_ENV=development
PORT=5000
MONGODB_URI=mongodb://localhost:27017/aistock

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d
BCRYPT_SALT_ROUNDS=10

# CORS
CORS_ORIGINS=http://localhost:3000,http://localhost:5100
SESSION_SECRET=change_me_session_secret

# Google OAuth (optional)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_CALLBACK_URL=http://localhost:5000/api/auth/google/callback
GOOGLE_OAUTH_SUCCESS_REDIRECT=http://localhost:3000
GOOGLE_OAUTH_FAILURE_REDIRECT=

# PayOS (optional)
PAYOS_CLIENT_ID=
PAYOS_API_KEY=
PAYOS_CHECKSUM_KEY=
PAYOS_RETURN_URL=
PAYOS_CANCEL_URL=
PAYOS_PRO_PRICE=50000

# Email (SMTP) — optional, alert emails disabled when SMTP_HOST is empty
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
EMAIL_FROM=noreply@aistocktrend.com
